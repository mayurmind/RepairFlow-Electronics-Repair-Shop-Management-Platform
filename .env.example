# Environment Configuration
NODE_ENV=development
PORT=4000

# Client Web Application URL (CORS, redirection links)
WEB_APP_URL=http://localhost:3000

# Backend API Base URL
API_BASE_URL=http://localhost:4000/api/v1

# Database Connection (Prisma)
DATABASE_URL=postgresql://postgres:postgrespassword@localhost:5432/repairflow?schema=public

# Authentication Security Tokens
JWT_ACCESS_SECRET=dev_jwt_access_secret_key_which_must_be_very_long_and_secure_12345
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=dev_jwt_refresh_secret_key_which_must_be_very_long_and_secure_67890
JWT_REFRESH_EXPIRES_IN=7d

# Cookies Security
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

# Expiring Reset & Decision Secrets
PASSWORD_RESET_SECRET=dev_password_reset_secret_key_998877
PUBLIC_TRACKING_SECRET=dev_public_tracking_secret_key_556677

# Object Storage (Mocked or local in dev, S3/Cloudinary in prod)
CLOUDINARY_CLOUD_NAME=placeholder
CLOUDINARY_API_KEY=placeholder
CLOUDINARY_API_SECRET=placeholder

# Sentry Monitoring
SENTRY_DSN=

# Logging level (debug, info, warn, error)
LOG_LEVEL=debug

# CORS Origins allowed to talk to the API
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
